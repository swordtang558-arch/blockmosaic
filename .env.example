# Copy to .env.local and fill in. Never commit real values.

# Public site origin (no trailing slash). Drives canonicals, OG urls, sitemap.
NEXT_PUBLIC_SITE_URL=https://blockmosaic.app

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_ID=

# Google AdSense publisher ID (e.g. ca-pub-0000000000000000). Leave empty to
# keep ad slots as visible placeholders. Wire real ad units later.
NEXT_PUBLIC_ADSENSE_ID=

# Google Search Console HTML-tag verification token (the content="..." value).
# Optional — sitemap-based verification also works (see README).
NEXT_PUBLIC_GSC_VERIFICATION=
